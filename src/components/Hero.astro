---
import { Check, Star, AlertTriangle } from 'lucide-react';
---

<section id="home" class="relative animated-gradient py-20 overflow-hidden">
  <!-- Decorative blobs -->
  <div class="absolute top-20 -left-20 w-96 h-96 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-float"></div>
  <div class="absolute bottom-20 -right-20 w-96 h-96 bg-purple-200 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-float anim-delay-300"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div class="space-y-8">
        <h1 class="text-5xl md:text-6xl font-bold leading-tight animate-fade-in-up">
          Your <span class="text-blue-600">Smile</span> is Our
          <span class="text-blue-600">Priority</span>
        </h1>
        
        <p class="text-xl text-gray-600 leading-relaxed animate-fade-in-up anim-delay-200">
          Experience exceptional dental care with our team of skilled professionals. 
          From routine cleanings to advanced cosmetic treatments, we're committed to 
          giving you the healthy, beautiful smile you deserve.
        </p>

        <!-- Key Benefits -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 animate-fade-in-up anim-delay-300">
          <div class="flex items-center space-x-2">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
              <Check class="w-4 h-4 text-green-600" />
            </div>
            <span class="text-sm font-medium text-gray-700">5+ Years Experience</span>
          </div>
          
          <div class="flex items-center space-x-2">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
              <Check class="w-4 h-4 text-green-600" />
            </div>
            <span class="text-sm font-medium text-gray-700">500+ Happy Patients</span>
          </div>
          
          <div class="flex items-center space-x-2">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
              <Check class="w-4 h-4 text-green-600" />
            </div>
            <span class="text-sm font-medium text-gray-700">Modern Technology</span>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up anim-delay-400">
          <a 
            href="#book-appointment" 
            class="bg-blue-600 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-blue-700 transition-all duration-300 text-center hover:shadow-xl hover:-translate-y-0.5"
          >
            Book Your Appointment
          </a>
          
          <a 
            href="tel:+919549213923" 
            class="border-2 border-blue-600 text-blue-600 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-blue-50 transition-all duration-300 text-center hover:shadow-md"
          >
            Call +919549213923
          </a>
        </div>

        <!-- Emergency Notice -->
        <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg animate-fade-in-up anim-delay-500">
          <div class="flex items-center">
            <AlertTriangle class="w-5 h-5 text-red-500 mr-2 flex-shrink-0" />
            <p class="text-red-700 font-medium">Dental Emergency? Call us 24/7 at +919549213923</p>
          </div>
        </div>
      </div>

      <!-- Right Content - Dental Team Photo -->
      <div class="relative animate-fade-in-up anim-delay-300">
        <div class="rounded-2xl overflow-hidden h-96 shadow-2xl">
          <img
            src="/dental_team.jpeg"
            alt="Professional Dental Team at Beyond Smile Dental Care"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>

        <!-- Floating Stats -->
        <div class="absolute -bottom-6 -left-6 bg-white rounded-xl shadow-xl p-4 animate-float">
          <div class="flex items-center space-x-3">
            <div class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center">
              <Star class="w-6 h-6 text-yellow-600 fill-yellow-600" />
            </div>
            <div>
              <p class="font-bold text-2xl text-gray-900">5.0</p>
              <p class="text-sm text-gray-600">Patient Rating</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
