---
import { MapPin, Phone, AlertTriangle, Mail, ArrowUp } from 'lucide-react';
---

<footer class="bg-gray-900 text-white py-16">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-4 md:grid-cols-2 gap-8 mb-12">
      
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <div class="flex items-center space-x-3 mb-6">
          <img src="/logo.png" alt="Beyond Smile Dental Care Logo" class="w-10 h-10 object-contain" />
          <div>
            <h3 class="text-xl font-bold font-heading">Beyond Smile Dental Care</h3>
            <p class="text-gray-400 text-sm">Your Smile, Our Priority</p>
          </div>
        </div>
        
        <p class="text-gray-400 mb-6 leading-relaxed text-sm">
          Providing exceptional dental care for over 5 years. We combine advanced 
          technology with compassionate treatment to give you the healthy, beautiful 
          smile you deserve.
        </p>

        <!-- Social Media -->
        <div class="flex space-x-3">
          <a href="https://www.facebook.com/share/1Dimy9i5UE/" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook" class="w-10 h-10 bg-gray-800 rounded-xl flex items-center justify-center hover:bg-primary-600 transition-colors duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/beyondsmilecare?igsh=MXgzNTl0djMyMnczcg==" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram" class="w-10 h-10 bg-gray-800 rounded-xl flex items-center justify-center hover:bg-pink-600 transition-colors duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-semibold mb-6 font-heading">Quick Links</h4>
        <ul class="space-y-3">
          {["Home","About Us","Our Services","Our Team","Contact Us","Book Appointment"].map((label, i) => {
            const hrefs = ["#home","#about","#services","#team","#contact","#book-appointment"];
            return (
              <li>
                <a href={hrefs[i]} class="text-gray-400 hover:text-white transition-colors duration-200 inline-flex items-center group">
                  <span class="w-0 group-hover:w-2 h-0.5 bg-primary-500 mr-0 group-hover:mr-2 transition-all duration-200 rounded-full"></span>
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-lg font-semibold mb-6 font-heading">Our Services</h4>
        <ul class="space-y-3">
          {["General Dentistry","Cosmetic Dentistry","Dental Implants","Orthodontics","Pediatric Dentistry","Emergency Care"].map(service => (
            <li>
              <a href="#services" class="text-gray-400 hover:text-white transition-colors duration-200 inline-flex items-center group">
                <span class="w-0 group-hover:w-2 h-0.5 bg-primary-500 mr-0 group-hover:mr-2 transition-all duration-200 rounded-full"></span>
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-lg font-semibold mb-6 font-heading">Contact Information</h4>
        
        <div class="space-y-4">
          <!-- Address -->
          <div class="flex items-start space-x-3">
            <MapPin class="w-5 h-5 text-primary-400 mt-1 flex-shrink-0" />
            <div>
              <p class="text-gray-400">
                Mk Mart, near Suchitra Bakery, <br/>
                Lokhra Chariali, <br/>
                Guwahati, Assam
              </p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-center space-x-3">
            <Phone class="w-5 h-5 text-primary-400 flex-shrink-0" />
            <a href="tel:+919549213923" class="text-gray-400 hover:text-white transition-colors duration-200">
              +919549213923 
            </a>
          </div>

          <!-- Emergency Phone -->
          <div class="flex items-center space-x-3">
            <AlertTriangle class="w-5 h-5 text-red-400 flex-shrink-0" />
            <div>
              <p class="text-red-400 text-sm font-medium">Emergency Line:</p>
              <a href="tel:+919549213923" class="text-red-400 hover:text-red-300 transition-colors duration-200">
                +919549213923
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-center space-x-3">
            <Mail class="w-5 h-5 text-primary-400 flex-shrink-0" />
            <a href="mailto:beyondsmiledentalcare@gmail.com" class="text-gray-400 hover:text-white transition-colors duration-200 text-sm">
              beyondsmiledentalcare@gmail.com
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Footer -->
    <div class="border-t border-gray-800 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="text-gray-500 text-sm mb-4 md:mb-0">
          &copy; 2025 Beyond Smile Dental Care. All rights reserved. |
          <a href="#" class="hover:text-white transition-colors duration-200 ml-1">Privacy Policy</a> |
          <a href="#" class="hover:text-white transition-colors duration-200 ml-1">Terms of Service</a>
        </div>
        <div class="text-center text-gray-500 text-sm">
          Designed with <span class="text-red-500" aria-label="love">&#9829;</span> by <a href="https://bordoisilalabs.com/" target="_blank" rel="noopener noreferrer" class="text-primary-400 hover:text-primary-300 font-semibold transition-colors duration-200">Bordoisila Labs</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<!-- Back to Top Button -->
<button 
  id="back-to-top"
  class="fixed bottom-8 right-8 bg-primary-600 text-white p-3 rounded-xl shadow-lg hover:bg-primary-700 transition-colors duration-200 opacity-0 invisible z-50"
  aria-label="Back to top"
>
  <ArrowUp class="w-5 h-5" />
</button>

<script>
  const backToTopButton = document.getElementById('back-to-top');
  
  window.addEventListener('scroll', () => {
    if (window.pageYOffset > 300) {
      backToTopButton?.classList.remove('opacity-0', 'invisible');
      backToTopButton?.classList.add('opacity-100', 'visible');
    } else {
      backToTopButton?.classList.add('opacity-0', 'invisible');
      backToTopButton?.classList.remove('opacity-100', 'visible');
    }
  });
  
  backToTopButton?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>