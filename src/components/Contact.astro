---
import { Phone, AlertTriangle, Mail, MapPin, Clock, Send, ExternalLink, CreditCard, BadgeCheck } from 'lucide-react';
---

<section id="contact" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-16">
      
      <!-- Left Side - Contact Information -->
      <div class="reveal-left">
        <h2 class="text-4xl font-bold text-gray-900 mb-6">Get in Touch</h2>
        <p class="text-xl text-gray-600 mb-8">
          Ready to schedule your appointment? We're here to help! Contact us today 
          to learn more about our services or book your visit.
        </p>

        <!-- Contact Methods -->
        <div class="space-y-6 mb-12">
          <!-- Phone -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mt-1 flex-shrink-0">
              <Phone class="w-6 h-6 text-blue-600" />
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">Phone</h3>
              <p class="text-gray-600">Call us during business hours</p>
              <a href="tel:+919549213923" class="text-blue-600 hover:text-blue-700 font-medium transition-colors">
                +919549213923
              </a>
            </div>
          </div>

          <!-- Emergency Phone -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mt-1 flex-shrink-0">
              <AlertTriangle class="w-6 h-6 text-red-600" />
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">Emergency Line</h3>
              <p class="text-gray-600">24/7 emergency dental care</p>
              <a href="tel:+919549213923" class="text-red-600 hover:text-red-700 font-medium transition-colors">
                +919549213923
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mt-1 flex-shrink-0">
              <Mail class="w-6 h-6 text-green-600" />
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">Email</h3>
              <p class="text-gray-600">Send us a message anytime</p>
              <a href="mailto:beyondsmiledentalcare@gmail.com" class="text-green-600 hover:text-green-700 font-medium transition-colors">
                beyondsmiledentalcare@gmail.com
              </a>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mt-1 flex-shrink-0">
              <MapPin class="w-6 h-6 text-purple-600" />
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">Visit Us</h3>
              <p class="text-gray-600">
                Mk Mart, near Suchitra Bakery,<br/>
                 Lokhra Chariali,<br/>
                Guwahati, Assam
              </p>
              <a href="https://maps.app.goo.gl/aV4V6xsbUCp4Fq8f7?g_st=aw" target="_blank" rel="noopener noreferrer" class="text-purple-600 hover:text-purple-700 font-medium inline-flex items-center transition-colors group">
                Get Directions
                <ExternalLink class="w-4 h-4 ml-1 group-hover:translate-x-0.5 transition-transform" />
              </a>
            </div>
          </div>
        </div>

        <!-- Business Hours -->
        <div class="bg-gray-50 rounded-xl p-8">
          <div class="flex items-center space-x-3 mb-6">
            <Clock class="w-6 h-6 text-blue-600" />
            <h3 class="text-2xl font-semibold text-gray-900">Business Hours</h3>
          </div>
          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-gray-600">Monday - Saturday</span>
              <span class="font-medium text-gray-900">10:00 AM - 7:30 PM</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Sunday</span>
              <span class="font-medium text-gray-900">10:00 AM - 2:30 PM</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Side - Map and Quick Contact -->
      <div class="reveal-right">
        <!-- Interactive Google Map -->
        <div class="rounded-2xl h-80 mb-8 overflow-hidden shadow-lg relative group">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3580.5489167!2d91.7491333!3d26.113145!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x375a5d0052b730d7:0xc5f2d1d4da0a0924!2sBeyond+Smile+Dental+Care!5e0!3m2!1sen!2sus!4v1731168453!16s%2Fg%2F11vq4cjhkr"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="w-full h-full"
            title="Beyond Smile Dental Care Location Map">
          </iframe>
          <!-- Fallback overlay with link -->
          <div class="absolute inset-0 bg-blue-600 bg-opacity-90 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="text-center text-white p-6">
              <MapPin class="w-12 h-12 mx-auto mb-4" />
              <h3 class="text-xl font-semibold mb-2">Get Directions</h3>
              <p class="mb-4">Click to open in Google Maps</p>
              <a
                href="https://www.google.com/maps/place/Beyond+Smile+Dental+Care!+Dr.+Bishal+Kalita/@26.113145,91.7491333,17z/data=!4m16!1m9!3m8!1s0x375a5d0052b730d7:0xc5f2d1d4da0a0924!2sBeyond+Smile+Dental+Care*21+Dr.+Bishal+Kalita!8m2!3d26.113145!4d91.7491333!9m1!1b1!16s%2Fg%2F11vq4cjhkr!3m5!1s0x375a5d0052b730d7:0xc5f2d1d4da0a0924!8m2!3d26.113145!4d91.7491333!16s%2Fg%2F11vq4cjhkr?entry=ttu&g_ep=EgoyMDI1MTEwNC4xIKXMDSoASAFQAw%3D%3D"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors"
              >
                <ExternalLink class="w-5 h-5 mr-2" />
                Open in Google Maps
              </a>
            </div>
          </div>
        </div>

        <!-- Quick Contact Form -->
        <div class="bg-blue-50 rounded-2xl p-8">
          <h3 class="text-2xl font-semibold text-gray-900 mb-6">Quick Message</h3>
          <form class="space-y-4" name="contact" netlify>
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-shadow duration-200"
                placeholder="Your full name"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-shadow duration-200"
                placeholder="Your phone number"
              />
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-gray-700 mb-2">Service of Interest</label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-shadow duration-200"
              >
                <option value="">Select a service</option>
                <option value="general">General Checkup</option>
                <option value="cleaning">Dental Cleaning</option>
                <option value="cosmetic">Cosmetic Dentistry</option>
                <option value="implants">Dental Implants</option>
                <option value="orthodontics">Orthodontics/Invisalign</option>
                <option value="emergency">Emergency Care</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none transition-shadow duration-200"
                placeholder="Tell us about your dental needs or questions..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-blue-600 text-white px-6 py-4 rounded-lg font-semibold hover:bg-blue-700 transition-all duration-300 flex items-center justify-center hover:shadow-lg hover:-translate-y-0.5"
            >
              <Send class="w-5 h-5 mr-2" />
              Send Message
            </button>
          </form>

          <div class="mt-6 text-center">
            <p class="text-gray-600 text-sm mb-4">Or contact us directly:</p>
            <div class="flex justify-center gap-4">
              <a
                href="tel:+919549213923"
                class="flex items-center gap-4 px-5 py-2.5 bg-white text-blue-600 rounded-lg hover:bg-blue-50 transition-all duration-300 shadow-sm hover:shadow-md"
              >
                <Phone class="w-5 h-5" />
                Call Now
              </a>

              <a
                href="mailto:beyondsmiledentalcare@gmail.com"
                class="flex items-center gap-4 px-5 py-2.5 bg-white text-green-600 rounded-lg hover:bg-green-50 transition-all duration-300 shadow-sm hover:shadow-md"
              >
                <Mail class="w-5 h-5" />
                Email
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Insurance & Payment Info -->
    <div class="mt-20 bg-gradient-to-r from-blue-50 to-purple-50 rounded-2xl p-12 reveal">
      <h3 class="text-3xl font-bold text-center text-gray-900 mb-8">Payment Options</h3>
      
      <div class="grid md:grid-cols-2 gap-8 max-w-2xl mx-auto">
        <div class="text-center reveal reveal-delay-1">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <CreditCard class="w-8 h-8 text-green-600" />
          </div>
          <h4 class="text-xl font-semibold text-gray-900 mb-2">Payment Plans</h4>
          <p class="text-gray-600">Flexible financing options available including interest-free payment plans</p>
        </div>

        <div class="text-center reveal reveal-delay-2">
          <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <BadgeCheck class="w-8 h-8 text-purple-600" />
          </div>
          <h4 class="text-xl font-semibold text-gray-900 mb-2">Accepted Payments</h4>
          <p class="text-gray-600">Cash, UPI and Debit cards</p>
        </div>
      </div>
    </div>
  </div>
</section>
