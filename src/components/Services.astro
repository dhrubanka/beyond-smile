---
import { Check, Stethoscope, Sparkles, Settings, Smile, Bone, Baby, Zap, ScanLine, Shield, Camera, AlertTriangle } from 'lucide-react';
---

<section id="services" class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Our Dental Services</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Comprehensive dental care tailored to your needs. From preventive treatments 
        to advanced cosmetic procedures, we offer the latest in modern dentistry.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      
      <!-- General Dentistry -->
      <div class="bg-white rounded-xl shadow-lg card-hover p-8 reveal">
        <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <Stethoscope class="w-8 h-8 text-blue-600" />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">General Dentistry</h3>
        <p class="text-gray-600 mb-6">
          Comprehensive oral health care including regular checkups, cleanings, and preventive treatments.
        </p>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Regular Checkups & Cleanings</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Dental X-Rays & Diagnostics</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Fluoride Treatments</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Oral Health Education</span></li>
        </ul>
      </div>

      <!-- Cosmetic Dentistry -->
      <div class="bg-white rounded-xl shadow-lg card-hover p-8 reveal reveal-delay-1">
        <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <Sparkles class="w-8 h-8 text-purple-600" />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Cosmetic Dentistry</h3>
        <p class="text-gray-600 mb-6">
          Transform your smile with our advanced cosmetic dental treatments and procedures.
        </p>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Professional Teeth Whitening</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Porcelain Veneers</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Dental Bonding</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Smile Makeovers</span></li>
        </ul>
      </div>

      <!-- Restorative Dentistry -->
      <div class="bg-white rounded-xl shadow-lg card-hover p-8 reveal reveal-delay-2">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <Settings class="w-8 h-8 text-green-600" />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Restorative Dentistry</h3>
        <p class="text-gray-600 mb-6">
          Restore damaged or missing teeth with our comprehensive restorative treatments.
        </p>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Dental Fillings</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Crowns & Bridges</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Root Canal Therapy</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Tooth Extractions</span></li>
        </ul>
      </div>

      <!-- Orthodontics -->
      <div class="bg-white rounded-xl shadow-lg card-hover p-8 reveal">
        <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <Smile class="w-8 h-8 text-orange-600" />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Orthodontics</h3>
        <p class="text-gray-600 mb-6">
          Straighten your teeth and improve your bite with modern orthodontic solutions.
        </p>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Traditional Braces</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Invisalign Clear Aligners</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Retainers & Maintenance</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Bite Correction</span></li>
        </ul>
      </div>

      <!-- Dental Implants -->
      <div class="bg-white rounded-xl shadow-lg card-hover p-8 reveal reveal-delay-1">
        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <Bone class="w-8 h-8 text-red-600" />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Dental Implants</h3>
        <p class="text-gray-600 mb-6">
          Permanent tooth replacement solutions that look, feel, and function like natural teeth.
        </p>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Single Tooth Implants</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Multiple Tooth Implants</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>All-on-4 Implants</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Implant-Supported Dentures</span></li>
        </ul>
      </div>

      <!-- Pediatric Dentistry -->
      <div class="bg-white rounded-xl shadow-lg card-hover p-8 reveal reveal-delay-2">
        <div class="w-16 h-16 bg-pink-100 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <Baby class="w-8 h-8 text-pink-600" />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Pediatric Dentistry</h3>
        <p class="text-gray-600 mb-6">
          Specialized dental care for children in a comfortable, kid-friendly environment.
        </p>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Children's Dental Exams</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Dental Sealants</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Cavity Prevention</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" /><span>Early Orthodontic Assessment</span></li>
        </ul>
      </div>
    </div>

    <!-- Emergency Services Banner -->
    <div class="bg-gradient-to-r from-red-600 to-red-700 text-white rounded-xl p-8 text-center reveal shadow-xl">
      <AlertTriangle class="w-12 h-12 mx-auto mb-4 text-red-200" />
      <h3 class="text-3xl font-bold mb-4">Dental Emergency?</h3>
      <p class="text-xl mb-6 max-w-2xl mx-auto">
        We provide 24/7 emergency dental care for urgent situations including severe pain, 
        knocked-out teeth, and dental trauma.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+919549213923" 
          class="bg-white text-red-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-all duration-300 hover:shadow-lg"
        >
          Call Emergency Line: +919549213923
        </a>
        <a 
          href="#book-appointment" 
          class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-red-600 transition-all duration-300"
        >
          Request Emergency Appointment
        </a>
      </div>
    </div>

    <!-- Technology Section -->
    <div class="mt-20">
      <h3 class="text-3xl font-bold text-center text-gray-900 mb-12 reveal">
        Advanced Technology & Modern Equipment
      </h3>
      
      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center reveal reveal-delay-1">
          <div class="w-20 h-20 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
            <Camera class="w-10 h-10 text-blue-600" />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Digital X-Rays</h4>
          <p class="text-gray-600 text-sm">Faster, safer, and more precise imaging</p>
        </div>

        <div class="text-center reveal reveal-delay-2">
          <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
            <Zap class="w-10 h-10 text-green-600" />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Laser Dentistry</h4>
          <p class="text-gray-600 text-sm">Minimally invasive treatments</p>
        </div>

        <div class="text-center reveal reveal-delay-3">
          <div class="w-20 h-20 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
            <ScanLine class="w-10 h-10 text-purple-600" />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">3D Imaging</h4>
          <p class="text-gray-600 text-sm">Comprehensive treatment planning</p>
        </div>

        <div class="text-center reveal reveal-delay-4">
          <div class="w-20 h-20 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform duration-300">
            <Shield class="w-10 h-10 text-orange-600" />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Sterilization</h4>
          <p class="text-gray-600 text-sm">Hospital-grade infection control</p>
        </div>
      </div>
    </div>
  </div>
</section>
