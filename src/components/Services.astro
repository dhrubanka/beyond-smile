---
import { Check, Stethoscope, Sparkles, Settings, Smile, Bone, Baby, Zap, ScanLine, Shield, Camera, AlertTriangle } from 'lucide-react';
---

<section id="services" class="py-24 bg-gray-50">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-12 reveal">
      <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-primary-100 text-primary-700 text-sm font-semibold tracking-wide mb-4">Our Services</span>
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Comprehensive Dental Care</h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        From preventive treatments to advanced cosmetic procedures, we offer the latest in modern dentistry tailored to your needs.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
      
      <!-- General Dentistry -->
      <div class="bg-white rounded-2xl shadow-sm card-hover p-8 reveal">
        <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center mb-6">
          <Stethoscope class="w-7 h-7 text-primary-600" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">General Dentistry</h3>
        <p class="text-gray-600 mb-6 text-sm leading-relaxed">
          Comprehensive oral health care including regular checkups, cleanings, and preventive treatments.
        </p>
        <ul class="space-y-2.5 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Regular Checkups & Cleanings</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Dental X-Rays & Diagnostics</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Fluoride Treatments</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Oral Health Education</span></li>
        </ul>
      </div>

      <!-- Cosmetic Dentistry -->
      <div class="bg-white rounded-2xl shadow-sm card-hover p-8 reveal reveal-delay-1">
        <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
          <Sparkles class="w-7 h-7 text-purple-600" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Cosmetic Dentistry</h3>
        <p class="text-gray-600 mb-6 text-sm leading-relaxed">
          Transform your smile with our advanced cosmetic dental treatments and procedures.
        </p>
        <ul class="space-y-2.5 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Professional Teeth Whitening</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Porcelain Veneers</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Dental Bonding</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Smile Makeovers</span></li>
        </ul>
      </div>

      <!-- Restorative Dentistry -->
      <div class="bg-white rounded-2xl shadow-sm card-hover p-8 reveal reveal-delay-2">
        <div class="w-14 h-14 bg-emerald-100 rounded-xl flex items-center justify-center mb-6">
          <Settings class="w-7 h-7 text-emerald-600" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Restorative Dentistry</h3>
        <p class="text-gray-600 mb-6 text-sm leading-relaxed">
          Restore damaged or missing teeth with our comprehensive restorative treatments.
        </p>
        <ul class="space-y-2.5 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Dental Fillings</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Crowns & Bridges</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Root Canal Therapy</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Tooth Extractions</span></li>
        </ul>
      </div>

      <!-- Orthodontics -->
      <div class="bg-white rounded-2xl shadow-sm card-hover p-8 reveal">
        <div class="w-14 h-14 bg-orange-100 rounded-xl flex items-center justify-center mb-6">
          <Smile class="w-7 h-7 text-orange-600" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Orthodontics</h3>
        <p class="text-gray-600 mb-6 text-sm leading-relaxed">
          Straighten your teeth and improve your bite with modern orthodontic solutions.
        </p>
        <ul class="space-y-2.5 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Traditional Braces</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Invisalign Clear Aligners</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Retainers & Maintenance</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Bite Correction</span></li>
        </ul>
      </div>

      <!-- Dental Implants -->
      <div class="bg-white rounded-2xl shadow-sm card-hover p-8 reveal reveal-delay-1">
        <div class="w-14 h-14 bg-rose-100 rounded-xl flex items-center justify-center mb-6">
          <Bone class="w-7 h-7 text-rose-600" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Dental Implants</h3>
        <p class="text-gray-600 mb-6 text-sm leading-relaxed">
          Permanent tooth replacement solutions that look, feel, and function like natural teeth.
        </p>
        <ul class="space-y-2.5 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Single Tooth Implants</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Multiple Tooth Implants</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">All-on-4 Implants</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Implant-Supported Dentures</span></li>
        </ul>
      </div>

      <!-- Pediatric Dentistry -->
      <div class="bg-white rounded-2xl shadow-sm card-hover p-8 reveal reveal-delay-2">
        <div class="w-14 h-14 bg-pink-100 rounded-xl flex items-center justify-center mb-6">
          <Baby class="w-7 h-7 text-pink-600" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Pediatric Dentistry</h3>
        <p class="text-gray-600 mb-6 text-sm leading-relaxed">
          Specialized dental care for children in a comfortable, kid-friendly environment.
        </p>
        <ul class="space-y-2.5 text-gray-600">
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Children's Dental Exams</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Dental Sealants</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Cavity Prevention</span></li>
          <li class="flex items-start"><Check class="w-4 h-4 text-emerald-500 mr-2 mt-0.5 flex-shrink-0" /><span class="text-sm">Early Orthodontic Assessment</span></li>
        </ul>
      </div>
    </div>

    <!-- Emergency Services Banner -->
    <div class="bg-gradient-to-r from-red-600 to-red-700 text-white rounded-2xl p-8 md:p-10 text-center reveal shadow-xl">
      <AlertTriangle class="w-12 h-12 mx-auto mb-4 text-red-200" />
      <h3 class="text-3xl font-bold mb-4">Dental Emergency?</h3>
      <p class="text-lg mb-6 max-w-2xl mx-auto text-red-100">
        We provide 24/7 emergency dental care for urgent situations including severe pain, 
        knocked-out teeth, and dental trauma.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:+919549213923" 
          class="bg-white text-red-600 px-8 py-3 rounded-xl font-semibold hover:bg-gray-100 transition-colors duration-200 hover:shadow-lg"
        >
          Call Emergency Line: +919549213923
        </a>
        <a 
          href="#book-appointment" 
          class="border-2 border-white text-white px-8 py-3 rounded-xl font-semibold hover:bg-white hover:text-red-600 transition-colors duration-200"
        >
          Request Emergency Appointment
        </a>
      </div>
    </div>

    <!-- Technology Section -->
    <div class="mt-16">
      <h3 class="text-3xl font-bold text-center text-gray-900 mb-10 reveal">
        Advanced Technology & Modern Equipment
      </h3>
      
      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center reveal reveal-delay-1">
          <div class="w-16 h-16 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <Camera class="w-8 h-8 text-primary-600" />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Digital X-Rays</h4>
          <p class="text-gray-500 text-sm">Faster, safer, and more precise imaging</p>
        </div>

        <div class="text-center reveal reveal-delay-2">
          <div class="w-16 h-16 bg-emerald-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <Zap class="w-8 h-8 text-emerald-600" />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Laser Dentistry</h4>
          <p class="text-gray-500 text-sm">Minimally invasive treatments</p>
        </div>

        <div class="text-center reveal reveal-delay-3">
          <div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <ScanLine class="w-8 h-8 text-purple-600" />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">3D Imaging</h4>
          <p class="text-gray-500 text-sm">Comprehensive treatment planning</p>
        </div>

        <div class="text-center reveal reveal-delay-4">
          <div class="w-16 h-16 bg-orange-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <Shield class="w-8 h-8 text-orange-600" />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Sterilization</h4>
          <p class="text-gray-500 text-sm">Hospital-grade infection control</p>
        </div>
      </div>
    </div>
  </div>
</section>