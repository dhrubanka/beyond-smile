---
import { BadgeCheck, Heart, Users } from 'lucide-react';
---

<section id="team" class="py-24 bg-gray-50">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-12 reveal">
      <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-primary-100 text-primary-700 text-sm font-semibold tracking-wide mb-4">Our Team</span>
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Meet Our Expert Team</h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Our experienced dental professionals are committed to providing you with 
        the highest quality care in a comfortable and friendly environment.
      </p>
    </div>

    <!-- Team Philosophy -->
    <div class="reveal-scale">
      <div class="bg-gradient-to-br from-primary-600 to-primary-700 text-white rounded-2xl p-10 md:p-14 text-center shadow-xl">
        <h3 class="text-3xl font-bold mb-6">Our Team Philosophy</h3>
        <p class="text-lg text-primary-100 mb-10 max-w-4xl mx-auto leading-relaxed">
          "We believe that exceptional dental care comes from combining advanced 
          clinical expertise with genuine compassion. Every member of our team is 
          committed to creating a positive, comfortable experience that builds 
          lasting relationships with our patients."
        </p>
        
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center reveal reveal-delay-1">
            <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
              <BadgeCheck class="w-7 h-7 text-white" />
            </div>
            <h4 class="text-lg font-semibold mb-2">Continuing Education</h4>
            <p class="text-primary-100 text-sm">Regular training to stay current with latest techniques</p>
          </div>

          <div class="text-center reveal reveal-delay-2">
            <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
              <Heart class="w-7 h-7 text-white" />
            </div>
            <h4 class="text-lg font-semibold mb-2">Patient-Centered Care</h4>
            <p class="text-primary-100 text-sm">Your comfort and health are our top priorities</p>
          </div>

          <div class="text-center reveal reveal-delay-3">
            <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
              <Users class="w-7 h-7 text-white" />
            </div>
            <h4 class="text-lg font-semibold mb-2">Collaborative Approach</h4>
            <p class="text-primary-100 text-sm">Working together to achieve your oral health goals</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>