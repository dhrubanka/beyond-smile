---
import { BadgeCheck, Heart, Users } from 'lucide-react';
---

<section id="team" class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-12 reveal">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Meet Our Expert Team</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Our experienced dental professionals are committed to providing you with 
        the highest quality care in a comfortable and friendly environment.
      </p>
    </div>

    <!-- Team Philosophy -->
    <div class="reveal-scale">
      <div class="bg-gradient-to-br from-blue-600 to-blue-700 text-white rounded-2xl p-12 text-center shadow-xl">
        <h3 class="text-3xl font-bold mb-6">Our Team Philosophy</h3>
        <p class="text-xl text-blue-100 mb-8 max-w-4xl mx-auto leading-relaxed">
          "We believe that exceptional dental care comes from combining advanced 
          clinical expertise with genuine compassion. Every member of our team is 
          committed to creating a positive, comfortable experience that builds 
          lasting relationships with our patients."
        </p>
        
        <div class="grid md:grid-cols-3 gap-8 mt-12">
          <div class="text-center reveal reveal-delay-1">
            <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
              <BadgeCheck class="w-8 h-8 text-white" />
            </div>
            <h4 class="text-xl font-semibold mb-2">Continuing Education</h4>
            <p class="text-blue-100">Regular training to stay current with latest techniques</p>
          </div>

          <div class="text-center reveal reveal-delay-2">
            <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
              <Heart class="w-8 h-8 text-white" />
            </div>
            <h4 class="text-xl font-semibold mb-2">Patient-Centered Care</h4>
            <p class="text-blue-100">Your comfort and health are our top priorities</p>
          </div>

          <div class="text-center reveal reveal-delay-3">
            <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4 backdrop-blur-sm">
              <Users class="w-8 h-8 text-white" />
            </div>
            <h4 class="text-xl font-semibold mb-2">Collaborative Approach</h4>
            <p class="text-blue-100">Working together to achieve your oral health goals</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
